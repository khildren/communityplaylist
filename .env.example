# Email (console backend for local dev — no SMTP needed)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Community Playlist <noreply@communityplaylist.com>

SITE_URL=https://local.communityplaylist.com
